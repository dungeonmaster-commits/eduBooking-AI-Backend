generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS — equivalent to Java's enum types
// ============================================================

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}



enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
enum ResourceType {
  COURSE
  LAB
  HARDWARE
  SEMINAR_HALL
  YOUTUBE_VIDEO
  YOUTUBE_PLAYLIST
  UDEMY_COURSE
  COURSERA_COURSE
  STUDY_MATERIAL
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

// ============================================================
// USER — Core authentication entity
// ============================================================

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  role             Role           @default(STUDENT)
  isVerified       Boolean        @default(false)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  profile          Profile?
  refreshTokens    RefreshToken[]
  bookings         Booking[]
  payments         Payment[]
  posts            Post[]
  comments         Comment[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  progress         Progress[]
  resources        Resource[]     @relation("InstructorResources") // ✅ added
  ratings    ResourceRating[]
  postLikes    PostLike[]
  commentLikes CommentLike[]
  
  @@map("users")
}

// ============================================================
// PROFILE — Extended user information (1-to-1 with User)
// ============================================================

model Profile {
  id             String    @id @default(uuid())
  userId         String    @unique
  firstName      String
  lastName       String
  bio            String?
  avatarUrl      String?
  branch         String?   // e.g., "Computer Science"
  semester       Int?
  university     String?
  linkedinUrl    String?
  githubUrl      String?
  resumeUrl      String?
  skills         String[]  // PostgreSQL array
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================================
// REFRESH TOKEN — For JWT refresh flow
// ============================================================

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  expiresAt   DateTime
  isRevoked   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================================
// RESOURCE — Marketplace items (courses, labs, hardware, halls)
// ============================================================

model Resource {
  id              String          @id @default(uuid())
  title           String
  description     String?
  type            ResourceType
  difficultyLevel DifficultyLevel @default(BEGINNER)
  price           Decimal         @db.Decimal(10, 2) @default(0)
  capacity        Int?            // for labs/halls
  location        String?         // for physical resources
  isAvailable     Boolean         @default(true)
  thumbnailUrl    String?
  tags            String[]
  branch          String[]        // target branches e.g. ["CSE", "ECE"]
  semester        Int[]           // target semesters e.g. [3, 4, 5]
  duration        Int?            // in minutes
  rating          Float?          // average rating
  totalRatings    Int             @default(0)
  enrolledCount   Int             @default(0)

  // External resource fields
  isExternal      Boolean         @default(false)
  externalUrl     String?         // original URL
  externalId      String?         // platform's own ID
  externalPlatform String?        // "youtube" | "udemy" | "coursera"
  externalData    Json?           // raw API response stored as JSON

  instructorId    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  instructor      User?           @relation("InstructorResources", fields: [instructorId], references: [id])
  bookings        Booking[]
  progress        Progress[]
  ratings         ResourceRating[]

  @@map("resources")
}

// New: Resource ratings by students
model ResourceRating {
  id          String    @id @default(uuid())
  resourceId  String
  userId      String
  rating      Int       // 1 to 5
  review      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  resource    Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@unique([resourceId, userId])  // one rating per user per resource
  @@map("resource_ratings")
}

// ============================================================
// BOOKING
// ============================================================

model Booking {
  id           String        @id @default(uuid())
  userId       String
  resourceId   String
  status       BookingStatus @default(PENDING)
  startTime    DateTime
  endTime      DateTime
  notes        String?
  
  // Cancellation tracking
  cancelledAt     DateTime?
  cancellationReason String?
  
  // Confirmation tracking
  confirmedAt  DateTime?
  confirmedBy  String?       // admin userId who confirmed

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id])
  resource     Resource      @relation(fields: [resourceId], references: [id])
  payment      Payment?

  @@map("bookings")
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id            String        @id @default(uuid())
  userId        String
  bookingId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("INR")
  status        PaymentStatus @default(PENDING)

  // Razorpay fields
  razorpayOrderId   String?   @unique  // our order, created before payment
  razorpayPaymentId String?   @unique  // Razorpay's ID, after payment success
  razorpaySignature String?            // signature for verification

  // Refund tracking
  refundId     String?
  refundedAt   DateTime?
  refundAmount Decimal?  @db.Decimal(10, 2)
  refundReason String?

  // Failure tracking
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId],    references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

// ============================================================
// COMMUNITY — Posts & Comments
// ============================================================

// ── Post ──────────────────────────────────────────────────────────────────────
model Post {
  id          String    @id @default(uuid())
  userId      String
  title       String
  content     String
  tags        String[]
  imageUrl    String?   // optional image attachment

  // Counters — stored for fast reads without joins
  likesCount    Int     @default(0)
  commentsCount Int     @default(0)
  viewsCount    Int     @default(0)

  isEdited    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likes       PostLike[]

  @@map("posts")
}

// ── PostLike — separate table for like tracking ───────────────────────────────
model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])  // one like per user per post
  @@map("post_likes")
}

// ── Comment ───────────────────────────────────────────────────────────────────
model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  isEdited  Boolean  @default(false)

  // Counters
  likesCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     CommentLike[]

  @@map("comments")
}

// ── CommentLike ───────────────────────────────────────────────────────────────
model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])  // one like per user per comment
  @@map("comment_likes")
}

// ============================================================
// MESSAGING
// ============================================================

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  isDeleted  Boolean  @default(false)  // soft delete
  readAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender     User     @relation("SentMessages",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])   // fast conversation lookup
  @@index([receiverId, isRead])     // fast unread count lookup
  @@map("messages")
}

// ============================================================
// PROGRESS TRACKING
// ============================================================

model Progress {
  id             String         @id @default(uuid())
  userId         String
  resourceId     String

  // Core tracking
  status         ProgressStatus @default(NOT_STARTED)
  percentage     Float          @default(0)    // 0.0 to 100.0

  // Engagement metrics — used by AI recommendation engine later
  timeSpentMins  Int            @default(0)    // total minutes spent
  sessionCount   Int            @default(0)    // how many times accessed
  notes          String?                       // personal notes
  personalRating Int?                          // student's own rating 1-5

  // External resource tracking
  isExternal       Boolean      @default(false)
  externalUrl      String?
  externalPlatform String?      // "youtube" | "udemy" | "coursera"

  // Timestamps
  startedAt      DateTime?
  lastAccessedAt DateTime       @default(now())
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource       Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@map("progress")
}